---
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { menuLinks } from "@/site.config";
import { siteConfig } from "../../site.config";
---

<header class="relative mb-28" id="main-header">
	<!-- 顶部栏：Logo + 搜索 + 主题切换 -->
	<div class="flex items-center justify-between sm:ps-18">
		<a
			aria-current={Astro.url.pathname === "/" ? "page" : false}
			class="inline-flex items-center gap-3"
			href="/"
		>
			<svg
				aria-hidden="true"
				class="h-12 w-7 sm:absolute sm:left-0 sm:top-0 sm:h-16 sm:w-10 transition-transform duration-300 hover:scale-110"
				fill="none"
				focusable="false"
				viewBox="0 0 240 240"
				xmlns="http://www.w3.org/2000/svg"
			>
				<title>星语宇宙 Logo</title>
				<circle cx="120" cy="120" r="50" fill="url(#planetGradient)" opacity="0.95"/>
				<defs>
					<radialGradient id="planetGradient" cx="40%" cy="40%">
						<stop offset="0%" style="stop-color:#9d8df1;stop-opacity:1" />
						<stop offset="100%" style="stop-color:#6b5dd3;stop-opacity:1" />
					</radialGradient>
				</defs>
				<ellipse cx="120" cy="120" rx="80" ry="20" fill="none" stroke="#9d8df1" stroke-width="4" opacity="0.7"/>
				<ellipse cx="120" cy="120" rx="65" ry="15" fill="none" stroke="#b8abf5" stroke-width="2" opacity="0.5"/>
				<circle cx="60" cy="60" r="2.5" fill="#fff" opacity="0.9">
					<animate attributeName="opacity" values="0.5;1;0.5" dur="2s" repeatCount="indefinite"/>
				</circle>
				<circle cx="180" cy="70" r="2" fill="#fff" opacity="0.8">
					<animate attributeName="opacity" values="0.4;0.9;0.4" dur="3s" repeatCount="indefinite"/>
				</circle>
				<circle cx="200" cy="140" r="2.5" fill="#fff" opacity="0.75">
					<animate attributeName="opacity" values="0.3;0.8;0.3" dur="2.5s" repeatCount="indefinite"/>
				</circle>
				<circle cx="50" cy="170" r="2" fill="#fff" opacity="0.85">
					<animate attributeName="opacity" values="0.5;1;0.5" dur="3.5s" repeatCount="indefinite"/>
				</circle>
				<path d="M 100 40 Q 140 60 160 100" stroke="#8b7de8" stroke-width="1.5" fill="none" opacity="0.4" stroke-dasharray="3,3"/>
			</svg>
			<span class="text-3xl sm:text-4xl font-extrabold tracking-wide bg-gradient-to-r from-purple-300 via-violet-400 to-blue-300 bg-clip-text text-transparent drop-shadow-[0_0_15px_rgba(157,141,241,0.5)]">{siteConfig.title}</span>
		</a>
		<div class="flex items-center gap-x-2">
			<Search />
			<ThemeToggle />
		</div>
	</div>

	<!-- 导航栏：全部横向排列 -->
	<nav
		aria-label="主菜单"
		class="flex flex-row flex-wrap gap-x-1 gap-y-1 mt-4 sm:ps-18"
		id="navigation-menu"
	>
		{
			menuLinks.map((link) => (
				<a
					aria-current={Astro.url.pathname === link.path ? "page" : false}
					class="text-accent px-3 py-2 font-semibold text-sm sm:text-base rounded-lg transition-all duration-300 hover:text-accent-2 hover:scale-105 hover:bg-accent/10"
					href={link.path}
				>
					{link.title}
				</a>
			))
		}
	</nav>
</header>
