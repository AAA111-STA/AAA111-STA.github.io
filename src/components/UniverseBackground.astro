		.ubg-nebula { opacity: .5; }
		.p1{width:65px;height:65px}.p2{width:50px;height:50px}.p3{width:38px;height:38px}
		.p4{width:58px;height:58px}.p5{width:42px;height:42px}.p6{width:28px;height:28px}.p7{width:32px;height:32px}
