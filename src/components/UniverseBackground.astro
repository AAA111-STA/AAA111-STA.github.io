</style>

<script>
	(function() {
		// ====== 视差滚动 ======
		let ticking = false;
		const stars = document.querySelector('.ubg-stars') as HTMLElement | null;
		const neb = document.querySelector('.ubg-nebula') as HTMLElement | null;
		const pl = document.querySelector('.ubg-planets') as HTMLElement | null;
		const ast = document.querySelector('.ubg-astronauts') as HTMLElement | null;

		function tick() {
			const y = window.pageYOffset;
			if (stars) stars.style.transform = `translateZ(-250px) scale(1.2) translateY(${y * 0.08}px)`;
			if (neb) neb.style.transform = `translateZ(-120px) scale(1.1) translateY(${y * 0.13}px)`;
			if (pl) pl.style.transform = `translateZ(40px) translateY(${y * 0.22}px)`;
			if (ast) ast.style.transform = `translateZ(130px) translateY(${y * 0.3}px)`;
			ticking = false;
		}

		window.addEventListener('scroll', () => {
			if (!ticking) { requestAnimationFrame(tick); ticking = true; }
		}, { passive: true });

		tick();

		// ====== 流星雨（canvas 逐帧绘制，满屏落下）======
		const canvas = document.querySelector('.ubg-meteors') as HTMLCanvasElement | null;
		const ctx = canvas ? canvas.getContext('2d') : null;

		if (canvas && ctx) {
			const g = ctx;                 // 收窄类型，供闭包使用
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const MAX = reduce ? 30 : 90;  // 同屏最大流星数（满屏密度）
			const rand = (min: number, max: number) => min + Math.random() * (max - min);

			let dpr = 1, W = 0, H = 0;

			function resize() {
				dpr = Math.min(window.devicePixelRatio || 1, 2);
				W = window.innerWidth;
				H = window.innerHeight;
				canvas!.width = Math.floor(W * dpr);
				canvas!.height = Math.floor(H * dpr);
				canvas!.style.width = W + 'px';
				canvas!.style.height = H + 'px';
				g.setTransform(dpr, 0, 0, dpr, 0, 0);
			}
			resize();
			window.addEventListener('resize', resize, { passive: true });

			// 单颗流星状态
			interface Meteor {
				x: number; y: number;      // 头部当前位置
				vx: number; vy: number;    // 速度（px/帧）
				len: number;               // 拖尾长度
				life: number; ttl: number; // 已存活 / 总寿命（帧）
				size: number;              // 亮头半径
				bright: number;            // 峰值亮度
			}
			const meteors: Meteor[] = [];

			function makeMeteor(): Meteor {
				// 方向：右上 → 左下。角度 30°~52°，速度决定 vx(负)/vy(正)
				const angle = rand(30, 52) * Math.PI / 180;
				const speed = rand(4, 8);            // 放慢：约原来一半
				return {
					// 起点覆盖满屏：横跨整宽并向右外延，纵向从屏顶上方到中下部
					x: rand(W * 0.05, W * 1.15),
					y: rand(-H * 0.25, H * 0.7),
					vx: -Math.cos(angle) * speed,
					vy: Math.sin(angle) * speed,
					len: rand(80, 260),
					life: 0,
					ttl: rand(120, 220),                 // 放慢后拉长寿命，才能划完全屏
					size: rand(1.2, 2.6),
					bright: rand(0.6, 1),
				};
			}

			function spawn() {
				if (meteors.length < MAX) meteors.push(makeMeteor());
			}

			// 随机节奏：偶尔爆发，偶尔稀疏
			let acc = 0, nextGap = rand(2, 9);
			let running = true;

			function draw() {
				g.clearRect(0, 0, W, H);

				for (let i = meteors.length - 1; i >= 0; i--) {
					const m = meteors[i];
					if (!m) continue;
					m.life++;
					m.x += m.vx;
					m.y += m.vy;

					// 淡入淡出：寿命前 15% 渐显，后 30% 渐隐
					const p = m.life / m.ttl;
					let alpha = m.bright;
					if (p < 0.15) alpha *= p / 0.15;
					else if (p > 0.7) alpha *= Math.max(0, (1 - p) / 0.3);

					// 拖尾终点（反速度方向）
					const mag = Math.hypot(m.vx, m.vy) || 1;
					const tx = m.x - (m.vx / mag) * m.len;
					const ty = m.y - (m.vy / mag) * m.len;

					// 拖尾渐变
					const grad = g.createLinearGradient(m.x, m.y, tx, ty);
					grad.addColorStop(0, `rgba(255,255,255,${(0.9 * alpha).toFixed(3)})`);
					grad.addColorStop(0.15, `rgba(210,232,255,${(0.65 * alpha).toFixed(3)})`);
					grad.addColorStop(0.45, `rgba(150,195,245,${(0.28 * alpha).toFixed(3)})`);
					grad.addColorStop(1, 'rgba(90,140,205,0)');

					g.strokeStyle = grad;
					g.lineWidth = 2;
					g.lineCap = 'round';
					g.beginPath();
					g.moveTo(m.x, m.y);
					g.lineTo(tx, ty);
					g.stroke();

					// 亮头（发光圆点）
					const hg = g.createRadialGradient(m.x, m.y, 0, m.x, m.y, m.size * 4);
					hg.addColorStop(0, `rgba(255,255,255,${alpha.toFixed(3)})`);
					hg.addColorStop(0.3, `rgba(255,246,214,${(0.85 * alpha).toFixed(3)})`);
					hg.addColorStop(1, 'rgba(190,220,255,0)');
					g.fillStyle = hg;
					g.beginPath();
					g.arc(m.x, m.y, m.size * 4, 0, Math.PI * 2);
					g.fill();

					// 移除：寿命耗尽或飞出屏幕
					if (m.life >= m.ttl || m.x < -m.len || m.y > H + m.len) {
						meteors.splice(i, 1);
					}
				}

				// 生成调度（高密度：间隔短、爆发频繁且量大）
				acc++;
				if (acc >= nextGap) {
					acc = 0;
					nextGap = rand(2, 9);
					const burst = Math.random() < 0.45 ? Math.floor(rand(3, 8)) : 2;
					for (let k = 0; k < burst; k++) spawn();
				}

				if (running) requestAnimationFrame(draw);
			}

			document.addEventListener('visibilitychange', () => {
				const wasRunning = running;
				running = !document.hidden;
				if (running && !wasRunning) requestAnimationFrame(draw);
			});

			requestAnimationFrame(draw);
		}
	})();
</script>
