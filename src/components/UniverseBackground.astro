---
// 宇宙背景组件 - 多层3D深空场景
---

<div class="universe-bg">
	<div class="ubg-stars"></div>
	<div class="ubg-nebula"></div>
	<div class="ubg-planets">
		<div class="p p1"></div>
		<div class="p p2"></div>
		<div class="p p3"></div>
		<div class="p p4"></div>
		<div class="p p5"></div>
		<div class="p p6"></div>
		<div class="p p7"></div>
	</div>

	<!-- 左上角 国际空间站 (ISS) -->
	<div class="ubg-iss" aria-hidden="true">
		<div class="iss-model">
			<!-- 中央桁架横梁 -->
			<div class="iss-truss"></div>
			<!-- 太阳能板：左右各两片大板 -->
			<div class="iss-panel pL1"></div>
			<div class="iss-panel pL2"></div>
			<div class="iss-panel pR1"></div>
			<div class="iss-panel pR2"></div>
			<!-- 散热器（浅色小板） -->
			<div class="iss-radiator rTop"></div>
			<div class="iss-radiator rBot"></div>
			<!-- 中央增压舱段 -->
			<div class="iss-core"></div>
			<!-- 前端对接舱 + 天线 -->
			<div class="iss-dock"></div>
			<div class="iss-antenna"></div>
		</div>
	</div>

	<!-- 3D 宇航员 -->
	<div class="ubg-astronauts">
		<div class="a3d a3d-1">
			<div class="a3d-model">
				<div class="a3d-helmet"><div class="a3d-visor"></div></div>
				<div class="a3d-neck"></div>
				<div class="a3d-torso"><div class="a3d-panel"></div></div>
				<div class="a3d-belt"></div>
				<div class="a3d-pack"></div>
				<div class="a3d-armL"><div class="a3d-glove"></div></div>
				<div class="a3d-armR"><div class="a3d-glove"></div></div>
				<div class="a3d-legL"><div class="a3d-boot"></div></div>
				<div class="a3d-legR"><div class="a3d-boot"></div></div>
				<div class="a3d-hose"></div>
			</div>
		</div>
		<div class="a3d a3d-2">
			<div class="a3d-model">
				<div class="a3d-helmet"><div class="a3d-visor"></div></div>
				<div class="a3d-neck"></div>
				<div class="a3d-torso"><div class="a3d-panel"></div></div>
				<div class="a3d-belt"></div>
				<div class="a3d-pack"></div>
				<div class="a3d-armL"><div class="a3d-glove"></div></div>
				<div class="a3d-armR"><div class="a3d-glove"></div></div>
				<div class="a3d-legL"><div class="a3d-boot"></div></div>
				<div class="a3d-legR"><div class="a3d-boot"></div></div>
				<div class="a3d-hose"></div>
			</div>
		</div>
	</div>

	<!-- 流星雨（canvas 逐帧绘制，满屏落下） -->
	<canvas class="ubg-meteors" aria-hidden="true"></canvas>

</div>

<style>
	.universe-bg {
		position: fixed; top: 0; left: 0; width: 100%; height: 100%;
		z-index: -1; overflow: hidden; pointer-events: none;
		perspective: 1800px; transform-style: preserve-3d;
		background: radial-gradient(ellipse at 50% 50%, #0d1025 0%, #080b1a 50%, #050810 100%);
	}

	/* ====== 星空 ====== */
	.ubg-stars {
		position: absolute; width: 100%; height: 100%;
		background-image:
			url('/starry-sky.jpg'),
			radial-gradient(2px 2px at 15% 20%, #fff0, transparent),
			radial-gradient(1.5px 1.5px at 35% 45%, #fffc, transparent),
			radial-gradient(2px 2px at 55% 15%, #fffe, transparent),
			radial-gradient(1px 1px at 70% 35%, #fffd, transparent),
			radial-gradient(2.5px 2.5px at 85% 55%, #ffff, transparent),
			radial-gradient(1px 1px at 25% 75%, #fffc, transparent),
			radial-gradient(2px 2px at 60% 80%, #fff0, transparent),
			radial-gradient(1.5px 1.5px at 40% 90%, #fffd, transparent),
			radial-gradient(2px 2px at 90% 10%, #fffe, transparent),
			radial-gradient(1px 1px at 10% 50%, #fffb, transparent),
			radial-gradient(2px 2px at 75% 95%, #ffff, transparent),
			radial-gradient(1.5px 1.5px at 50% 60%, #fffc, transparent);
		background-size: cover, 300px 300px, 250px 250px, 350px 350px, 200px 200px, 280px 280px, 320px 320px, 260px 260px, 300px 300px, 240px 240px, 280px 280px, 350px 350px, 220px 220px;
		background-position: center, 0% 0%, 30% 20%, 60% 10%, 80% 30%, 10% 60%, 50% 70%, 70% 80%, 20% 85%, 90% 5%, 15% 40%, 80% 90%, 45% 50%;
		background-repeat: no-repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat;
		animation: twinkle 4s ease-in-out infinite alternate;
		transform: translateZ(-250px) scale(1.2);
	}
	@keyframes twinkle { 0%,100%{opacity:.7} 50%{opacity:1} }

	/* ====== 星云 ====== */
	.ubg-nebula {
		position: absolute; width: 100%; height: 100%;
		background:
			radial-gradient(ellipse at 25% 30%, rgba(70,60,180,0.18) 0%, transparent 55%),
			radial-gradient(ellipse at 75% 65%, rgba(30,20,100,0.15) 0%, transparent 50%),
			radial-gradient(ellipse at 50% 45%, rgba(40,80,140,0.1) 0%, transparent 60%),
			radial-gradient(ellipse at 65% 15%, rgba(100,60,160,0.08) 0%, transparent 45%);
		animation: nebDrift 18s ease-in-out infinite alternate;
		transform: translateZ(-120px) scale(1.1);
	}
	@keyframes nebDrift {
		0%{transform:translate(0,0) scale(1)} 50%{transform:translate(25px,-20px) scale(1.06)}
		100%{transform:translate(-15px,15px) scale(.97)}
	}

	/* ====== 行星 ====== */
	.ubg-planets { position: absolute; width: 100%; height: 100%; transform: translateZ(40px); }
	.p { position: absolute; border-radius: 50%; transform-style: preserve-3d; }
	/* -- 木星：不等宽大气带 + 极区压暗 + 大红斑 -- */
	.p1 { width:130px; height:130px; top:12%; right:8%;
		background:
			/* 高光 */
			radial-gradient(circle at 30% 25%, rgba(255,255,255,.3), transparent 40%),
			/* 极区压暗，使条纹包裹球面 */
			radial-gradient(150% 90% at 50% 50%, transparent 55%, rgba(60,35,15,.55) 100%),
			/* 不等宽的横向大气带（赤道亮带、深褐带、温带） */
			linear-gradient(180deg,
				#c9a06a 0%, #bb9058 5%,
				#e7d3ac 10%, #efe0bd 15%,
				#a9793f 20%, #9c6b34 25%,
				#dcc190 30%, #e9d4a6 37%,
				#b07f45 43%, #c99f68 49%,
				#f0e2be 54%, #e3cd9e 60%,
				#9a6a34 66%, #ac7c46 72%,
				#dcc292 79%, #cdaa73 86%,
				#b28850 92%, #a4773f 100%);
		box-shadow:inset -30px -25px 55px rgba(0,0,0,.62), inset 14px 10px 28px rgba(255,238,200,.24), 0 0 55px rgba(244,164,96,.45);
		animation:pf1 22s ease-in-out infinite; }
	.p1::after { content:''; position:absolute; width:34px; height:20px; top:57%; left:22%;
		background:
			radial-gradient(ellipse at 42% 38%, #e0684a, #c13c26 42%, #8f2415 70%, #661a0e);
		border-radius:50%; transform:rotate(-8deg);
		box-shadow:inset -3px -2px 8px rgba(0,0,0,.5), inset 2px 2px 5px rgba(255,180,140,.4), 0 0 6px rgba(180,50,30,.4); }

	/* -- 海王星：深蓝冰巨星，深浅蓝带 + 极区压暗 -- */
	.p2 { width:95px; height:95px; bottom:18%; left:12%;
		background:
			radial-gradient(circle at 34% 28%, rgba(255,255,255,.32), transparent 38%),
			radial-gradient(150% 90% at 50% 50%, transparent 55%, rgba(10,20,55,.6) 100%),
			linear-gradient(180deg,
				#3f63bd 0%, #38559f 12%,
				#5679d4 22%, #6b8ce0 28%,
				#33509a 38%, #2c4890 46%,
				#4c72cc 55%, #5a80d6 62%,
				#2d4a92 72%, #274285 82%,
				#3a5cb0 92%, #2c4a90 100%),
			radial-gradient(circle at 50% 50%, #3f5fb5, #22407e 72%, #16295a);
		box-shadow:inset -22px -20px 40px rgba(0,0,0,.52), inset 10px 8px 22px rgba(180,205,255,.2), 0 0 45px rgba(65,105,225,.5);
		animation:pf2 19s ease-in-out infinite; }
	.p2::after { content:''; position:absolute; width:20px; height:11px; top:40%; left:52%;
		background:radial-gradient(ellipse at 45% 40%, rgba(40,60,120,.9), rgba(25,40,90,.6) 70%, transparent);
		border-radius:50%; transform:rotate(-6deg); }

	/* -- 天王星：青绿冰巨星 + 竖直光环 -- */
	.p3 { width:75px; height:75px; top:55%; right:22%;
		background:
			radial-gradient(circle at 38% 30%, rgba(255,255,255,.32), transparent 42%),
			radial-gradient(circle at 50% 50%, #a8e6e0, #6fc4c0 48%, #3d8f8d 78%, #256463);
		box-shadow:inset -15px -15px 30px rgba(0,0,0,.45), 0 0 35px rgba(120,210,205,.5);
		animation:pf3 25s ease-in-out infinite; }
	.p3::after { content:''; position:absolute; top:50%; left:50%; width:24%; height:150%;
		background:linear-gradient(to right, transparent, rgba(150,230,225,.55) 40%, rgba(200,245,240,.7) 50%, rgba(150,230,225,.55) 60%, transparent);
		border-radius:50%; transform:translate(-50%,-50%) rotateY(78deg) rotate(12deg);
		box-shadow:0 0 14px rgba(150,230,225,.4); }

	/* -- 土星：不等宽沙金带 + 极区压暗 + 显著光环系统 -- */
	.p4 { width:115px; height:115px; top:72%; right:12%;
		background:
			radial-gradient(circle at 32% 26%, rgba(255,255,255,.3), transparent 40%),
			radial-gradient(150% 90% at 50% 50%, transparent 56%, rgba(80,55,20,.5) 100%),
			linear-gradient(180deg,
				#e2c896 0%, #d8bb82 8%,
				#f2e4c0 15%, #f6eccd 22%,
				#cda877 28%, #c79f68 34%,
				#ead7a8 42%, #f0e0ba 50%,
				#cfae78 58%, #dcc08c 66%,
				#f1e3bf 74%, #e6d2a2 82%,
				#cba873 90%, #d7ba86 100%);
		box-shadow:inset -22px -20px 40px rgba(0,0,0,.52), inset 10px 8px 24px rgba(255,246,214,.22), 0 0 48px rgba(214,180,120,.45);
		animation:pf4 24s ease-in-out infinite; }
	.p4::before { content:''; position:absolute; top:50%; left:50%; width:230%; height:64%;
		background:
			radial-gradient(ellipse at 50% 50%,
				transparent 0%, transparent 30%,
				rgba(200,180,140,.15) 32%, rgba(225,205,165,.75) 38%,
				rgba(180,152,108,.85) 45%, rgba(150,124,86,.3) 49%,
				transparent 50%, transparent 100%);
		border-radius:50%; transform:translate(-50%,-50%) rotateX(74deg);
		z-index:-1; }
	.p4::after { content:''; position:absolute; top:50%; left:50%; width:230%; height:64%;
		background:
			radial-gradient(ellipse at 50% 50%,
				transparent 0%, transparent 50%,
				rgba(180,152,108,.85) 51%, rgba(225,205,165,.75) 55%,
				rgba(200,180,140,.4) 61%, transparent 64%, transparent 100%);
		border-radius:50%; transform:translate(-50%,-50%) rotateX(74deg);
		clip-path:inset(50% 0 0 0); }

	/* -- 地球：海洋 + 陆地 + 云 -- */
	.p5 { width:80px; height:80px; top:8%; left:22%;
		background:
			radial-gradient(circle at 32% 26%, rgba(255,255,255,.4), transparent 34%),
			radial-gradient(ellipse at 62% 58%, #3f8c3a 0%, #2f6b2f 14%, transparent 32%),
			radial-gradient(ellipse at 34% 68%, #46953f 0%, #2f6b2f 12%, transparent 26%),
			radial-gradient(ellipse at 70% 30%, #3f8c3a 0%, transparent 20%),
			radial-gradient(circle at 46% 46%, #4a97dc, #2b6cb0 56%, #17436f 82%);
		box-shadow:inset -16px -15px 28px rgba(0,0,0,.5), 0 0 38px rgba(70,150,220,.55);
		animation:pf5 30s ease-in-out infinite; }
	.p5::after { content:''; position:absolute; inset:0; border-radius:50%;
		background:
			radial-gradient(ellipse at 25% 40%, rgba(255,255,255,.5) 0 6%, transparent 12%),
			radial-gradient(ellipse at 68% 62%, rgba(255,255,255,.45) 0 5%, transparent 11%),
			radial-gradient(ellipse at 50% 20%, rgba(255,255,255,.4) 0 4%, transparent 9%);
		opacity:.7; }

	/* -- 月球：灰白 + 环形山 -- */
	.p6 { width:50px; height:50px; top:42%; left:6%;
		background:
			radial-gradient(circle at 62% 34%, rgba(0,0,0,.16) 0 3px, transparent 4px),
			radial-gradient(circle at 40% 60%, rgba(0,0,0,.18) 0 5px, transparent 6px),
			radial-gradient(circle at 70% 66%, rgba(0,0,0,.13) 0 2.5px, transparent 3.5px),
			radial-gradient(circle at 30% 40%, rgba(0,0,0,.12) 0 3px, transparent 4px),
			radial-gradient(circle at 36% 30%, rgba(255,255,255,.35), transparent 42%),
			radial-gradient(circle at 47% 47%, #e0e0e0, #b6b6b6 52%, #8a8a8a 80%);
		box-shadow:inset -10px -8px 18px rgba(0,0,0,.5), 0 0 22px rgba(200,200,200,.4);
		animation:pf6 16s ease-in-out infinite; }

	/* -- 火星：铁锈色 + 极冠 + 陨坑 -- */
	.p7 { width:60px; height:60px; bottom:8%; right:50%;
		background:
			radial-gradient(circle at 50% 12%, rgba(255,255,255,.85) 0 4%, rgba(255,255,255,.35) 7%, transparent 12%),
			radial-gradient(circle at 58% 40%, rgba(0,0,0,.12) 0 4px, transparent 5px),
			radial-gradient(circle at 35% 55%, rgba(90,30,15,.4) 0 6px, transparent 8px),
			radial-gradient(circle at 36% 30%, rgba(255,220,180,.35), transparent 40%),
			radial-gradient(circle at 48% 50%, #e07b53, #c0562f 50%, #8b3a1e 78%, #5c2413);
		box-shadow:inset -12px -10px 22px rgba(0,0,0,.5), 0 0 28px rgba(210,90,50,.45);
		animation:pf7 27s ease-in-out infinite; }

	@keyframes pf1 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(-35px)translateX(22px)} }
	@keyframes pf2 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(28px)translateX(-18px)} }
	@keyframes pf3 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(-22px)translateX(-28px)} }
	@keyframes pf4 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(-18px)translateX(-22px)} }
	@keyframes pf5 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(-28px)translateX(12px)} }
	@keyframes pf6 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(22px)translateX(-16px)} }
	@keyframes pf7 { 0%,100%{transform:translateY(0)translateX(0)} 50%{transform:translateY(-12px)translateX(28px)} }

	/* ====== 国际空间站（左上角，纯CSS，放大版） ====== */
	.ubg-iss {
		position: absolute; top: 5%; left: 3%;
		width: 420px; height: 210px;
		transform: translateZ(90px);
		animation: issFloat 30s ease-in-out infinite;
		filter: drop-shadow(0 0 22px rgba(150,190,255,.4)) drop-shadow(0 14px 32px rgba(0,0,0,.55));
	}
	.iss-model {
		position: absolute; inset: 0;
		transform: rotate(-16deg);
		transform-style: preserve-3d;
	}

	/* 中央桁架（横梁，贯穿整体） */
	.iss-truss {
		position: absolute; top: 50%; left: 50%;
		width: 320px; height: 14px; transform: translate(-50%,-50%);
		background: linear-gradient(180deg, #d6dae0, #a4abb4 45%, #767c85);
		border-radius: 4px;
		box-shadow: inset 0 -3px 5px rgba(0,0,0,.35), 0 2px 5px rgba(0,0,0,.4);
		z-index: 5;
	}
	.iss-truss::before { /* 桁架网格纹理 */
		content:''; position:absolute; inset:0; border-radius:4px;
		background: repeating-linear-gradient(90deg, transparent 0 11px, rgba(0,0,0,.2) 11px 13px);
	}

	/* 中央增压舱段（居中圆柱模块组） */
	.iss-core {
		position: absolute; top: 50%; left: 50%;
		width: 104px; height: 40px; transform: translate(-50%,-50%);
		background: linear-gradient(180deg, #f1f3f6, #d2d6dc 40%, #e2e6eb 60%, #b3b8c0);
		border-radius: 20px;
		box-shadow: inset -6px -4px 13px rgba(0,0,0,.28), inset 4px 3px 9px rgba(255,255,255,.55), 0 3px 11px rgba(0,0,0,.4);
		z-index: 8;
	}
	.iss-core::before { /* 舱段分节环 */
		content:''; position:absolute; inset:0; border-radius:20px;
		background: repeating-linear-gradient(90deg, transparent 0 22px, rgba(0,0,0,.14) 22px 25px);
	}
	.iss-core::after { /* 侧向舷窗排 */
		content:''; position:absolute; top:50%; left:50%; width:70px; height:7px;
		transform:translate(-50%,-50%);
		background: repeating-linear-gradient(90deg, rgba(90,150,220,.75) 0 5px, transparent 5px 13px);
		border-radius:4px;
	}

	/* 前端对接舱 */
	.iss-dock {
		position: absolute; top: 50%; left: 50%;
		width: 26px; height: 24px; transform: translate(-50%,-50%) translateX(64px);
		background: radial-gradient(circle at 40% 35%, #fdfdfd, #c6cbd2 60%, #8f959e);
		border-radius: 6px 10px 10px 6px;
		box-shadow: 0 0 8px rgba(180,210,255,.5), inset -2px 0 5px rgba(0,0,0,.3);
		z-index: 9;
	}
	/* 前端天线/桁架端 */
	.iss-antenna {
		position: absolute; top: 50%; left: 50%;
		width: 34px; height: 3px; transform: translate(-50%,-50%) translateX(96px);
		background: linear-gradient(90deg, #b8bdc5, #7e848d);
		z-index: 4;
	}
	.iss-antenna::after {
		content:''; position:absolute; right:-6px; top:50%; width:11px; height:11px;
		transform:translateY(-50%);
		background:radial-gradient(circle, #e8ebef, #9aa1aa);
		border-radius:50%; box-shadow:0 0 6px rgba(180,210,255,.5);
	}

	/* 太阳能板：左右各两片大板（金色，经典 ISS 配色） */
	.iss-panel {
		position: absolute; top: 50%;
		width: 88px; height: 132px; transform: translateY(-50%);
		background:
			linear-gradient(90deg, rgba(0,0,0,.28) 0 1px, transparent 1px 100%) 0 0/22px 100%,
			linear-gradient(0deg, rgba(0,0,0,.22) 0 1px, transparent 1px 100%) 0 0/100% 16px,
			linear-gradient(135deg, #c79a3e, #9c7527 42%, #b98f37 60%, #6e4f18);
		border: 1px solid rgba(210,175,90,.6);
		box-shadow: inset 0 0 16px rgba(255,215,120,.3), 0 0 12px rgba(180,140,50,.3);
		z-index: 3;
	}
	.iss-panel.pL1 { right: 50%; margin-right: 70px; }
	.iss-panel.pL2 { right: 50%; margin-right: 166px; }
	.iss-panel.pR1 { left: 50%; margin-left: 70px; }
	.iss-panel.pR2 { left: 50%; margin-left: 166px; }
	/* 板与桁架之间的连接杆 */
	.iss-panel::after {
		content:''; position:absolute; top:50%; width:20px; height:4px;
		background:#9aa1aa; transform:translateY(-50%);
	}
	.iss-panel.pL1::after, .iss-panel.pL2::after { right:-20px; }
	.iss-panel.pR1::after, .iss-panel.pR2::after { left:-20px; }

	/* 散热器（浅色小板，位于核心舱上下方） */
	.iss-radiator {
		position: absolute; left: 50%;
		width: 46px; height: 30px;
		background: linear-gradient(180deg, #e4e8ed, #b8bdc5);
		border: 1px solid rgba(150,156,165,.6);
		box-shadow: inset 0 0 8px rgba(0,0,0,.2);
		z-index: 2;
	}
	.iss-radiator.rTop { top: 50%; transform: translate(-50%,-50%) translateY(-46px); }
	.iss-radiator.rBot { top: 50%; transform: translate(-50%,-50%) translateY(46px); }
	.iss-radiator::before {
		content:''; position:absolute; inset:0;
		background: repeating-linear-gradient(0deg, transparent 0 4px, rgba(0,0,0,.16) 4px 5px);
	}

	@keyframes issFloat {
		0%,100%{ transform: translateZ(90px) translate(0,0); }
		50%{ transform: translateZ(90px) translate(22px,15px); }
	}

	/* ====== 纯CSS 3D宇航员模型 ====== */
	.ubg-astronauts {
		position: absolute; width: 100%; height: 100%;
		transform: translateZ(130px); perspective: 800px;
	}
	.a3d {
		position: absolute; width: 100px; height: 200px;
		transform-style: preserve-3d;
		filter: drop-shadow(0 0 30px rgba(150,190,255,.5)) drop-shadow(0 15px 40px rgba(0,0,0,.5));
	}
	.a3d-1 { top: 38%; left: 4%; animation: aFloat1 30s ease-in-out infinite; }
	.a3d-2 { top: 65%; right: 6%; animation: aFloat2 34s ease-in-out infinite; }

	.a3d-model {
		width: 100%; height: 100%; position: relative;
		transform-style: preserve-3d;
		animation: aSpin3D 16s ease-in-out infinite;
	}
	@keyframes aSpin3D {
		0%,100%{transform:rotateY(-12deg) rotateX(3deg)}
		25%{transform:rotateY(10deg) rotateX(-4deg)}
		50%{transform:rotateY(14deg) rotateX(5deg)}
