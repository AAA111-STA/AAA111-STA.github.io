---
// 宇宙背景组件 - 包含星星、星云、行星、宇航员
---

<div class="universe-background">
	<!-- 星空层 -->
	<div class="stars-layer"></div>

	<!-- 星云层 -->
	<div class="nebula-layer"></div>

	<!-- 行星层 -->
	<div class="planets-layer">
		<div class="planet planet-1"></div>
		<div class="planet planet-2"></div>
		<div class="planet planet-3"></div>
	</div>

	<!-- 宇航员层 -->
	<div class="astronaut-layer">
		<div class="astronaut"></div>
	</div>
</div>

<style>
	.universe-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	/* 星空层 - 多层闪烁星星 */
	.stars-layer {
		position: absolute;
		width: 100%;
		height: 100%;
		background-image:
			radial-gradient(2px 2px at 20% 30%, white, transparent),
			radial-gradient(2px 2px at 60% 70%, rgba(255, 255, 255, 0.8), transparent),
			radial-gradient(1px 1px at 50% 50%, white, transparent),
			radial-gradient(1px 1px at 80% 10%, rgba(255, 255, 255, 0.6), transparent),
			radial-gradient(2px 2px at 90% 60%, white, transparent),
			radial-gradient(1px 1px at 33% 80%, rgba(255, 255, 255, 0.7), transparent),
			radial-gradient(1px 1px at 15% 90%, white, transparent),
			radial-gradient(1px 1px at 40% 20%, rgba(255, 255, 255, 0.9), transparent),
			radial-gradient(2px 2px at 75% 45%, white, transparent),
			radial-gradient(1px 1px at 25% 65%, rgba(255, 255, 255, 0.8), transparent);
		background-size: 200% 200%;
		background-position:
			0% 0%, 40% 60%, 130% 270%, 70% 100%,
			100% 100%, 50% 100%, 80% 30%, 20% 80%,
			60% 20%, 90% 90%;
		animation: twinkle 4s ease-in-out infinite alternate;
	}

	@keyframes twinkle {
		0%, 100% {
			opacity: 0.5;
		}
		50% {
			opacity: 0.9;
		}
	}

	/* 星云层 - 彩色渐变云雾 */
	.nebula-layer {
		position: absolute;
		width: 100%;
		height: 100%;
		background:
			radial-gradient(ellipse at 20% 30%, rgba(138, 43, 226, 0.15) 0%, transparent 50%),
			radial-gradient(ellipse at 80% 70%, rgba(75, 0, 130, 0.12) 0%, transparent 50%),
			radial-gradient(ellipse at 50% 50%, rgba(25, 25, 112, 0.1) 0%, transparent 60%),
			radial-gradient(ellipse at 70% 20%, rgba(72, 61, 139, 0.08) 0%, transparent 45%);
		animation: nebulaDrift 20s ease-in-out infinite alternate;
	}

	@keyframes nebulaDrift {
		0% {
			transform: translate(0, 0) scale(1);
			opacity: 0.6;
		}
		50% {
			transform: translate(20px, -15px) scale(1.05);
			opacity: 0.8;
		}
		100% {
			transform: translate(-10px, 10px) scale(0.98);
			opacity: 0.7;
		}
	}

	/* 行星层 */
	.planets-layer {
		position: absolute;
		width: 100%;
		height: 100%;
	}

	.planet {
		position: absolute;
		border-radius: 50%;
		opacity: 0.6;
		filter: blur(1px);
	}

	.planet-1 {
		width: 120px;
		height: 120px;
		top: 15%;
		right: 10%;
		background: radial-gradient(circle at 30% 30%, #f4a460, #8b4513 60%, #2c1810);
		box-shadow:
			inset -20px -20px 40px rgba(0, 0, 0, 0.5),
			0 0 40px rgba(244, 164, 96, 0.3);
		animation: planetFloat1 30s ease-in-out infinite;
	}

	.planet-2 {
		width: 80px;
		height: 80px;
		bottom: 20%;
		left: 15%;
		background: radial-gradient(circle at 35% 35%, #add8e6, #4169e1 50%, #191970);
		box-shadow:
			inset -15px -15px 30px rgba(0, 0, 0, 0.4),
			0 0 30px rgba(65, 105, 225, 0.4);
		animation: planetFloat2 25s ease-in-out infinite;
	}

	.planet-3 {
		width: 60px;
		height: 60px;
		top: 60%;
		right: 25%;
		background: radial-gradient(circle at 40% 30%, #dda0dd, #8b008b 55%, #4b0082);
		box-shadow:
			inset -10px -10px 20px rgba(0, 0, 0, 0.4),
			0 0 25px rgba(221, 160, 221, 0.3);
		animation: planetFloat3 35s ease-in-out infinite;
	}

	@keyframes planetFloat1 {
		0%, 100% {
			transform: translateY(0px) translateX(0px) rotate(0deg);
		}
		50% {
			transform: translateY(-30px) translateX(20px) rotate(5deg);
		}
	}

	@keyframes planetFloat2 {
		0%, 100% {
			transform: translateY(0px) translateX(0px) rotate(0deg);
		}
		50% {
			transform: translateY(25px) translateX(-15px) rotate(-4deg);
		}
	}

	@keyframes planetFloat3 {
		0%, 100% {
			transform: translateY(0px) translateX(0px) rotate(0deg);
		}
		50% {
			transform: translateY(-20px) translateX(-25px) rotate(3deg);
		}
	}

	/* 宇航员层 */
	.astronaut-layer {
		position: absolute;
		width: 100%;
		height: 100%;
	}

	.astronaut {
		position: absolute;
		width: 100px;
		height: 120px;
		top: 40%;
		left: 5%;
		opacity: 0.7;
		animation: astronautFloat 40s ease-in-out infinite;
	}

	.astronaut::before {
		content: "👨‍🚀";
		font-size: 80px;
		position: absolute;
		filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
	}

	@keyframes astronautFloat {
		0% {
			transform: translate(0, 0) rotate(-5deg);
		}
		25% {
			transform: translate(calc(90vw), -100px) rotate(5deg);
		}
		50% {
			transform: translate(calc(85vw), 50px) rotate(-3deg);
		}
		75% {
			transform: translate(calc(45vw), -50px) rotate(4deg);
		}
		100% {
			transform: translate(0, 0) rotate(-5deg);
		}
	}

	/* 响应式调整 */
	@media (max-width: 768px) {
		.planet-1 {
			width: 80px;
			height: 80px;
		}

		.planet-2 {
			width: 60px;
			height: 60px;
		}

		.planet-3 {
			width: 40px;
			height: 40px;
		}

		.astronaut {
			width: 60px;
			height: 72px;
		}

		.astronaut::before {
			font-size: 50px;
		}
	}
</style>
