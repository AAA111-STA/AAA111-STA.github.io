---
// 宇宙背景组件 - 包含星星、星云、行星、宇航员
---

<div class="universe-background">
	<!-- 星空层 -->
	<div class="stars-layer"></div>

	<!-- 星云层 -->
	<div class="nebula-layer"></div>

	<!-- 行星层 -->
	<div class="planets-layer">
		<div class="planet planet-1"></div>
		<div class="planet planet-2"></div>
		<div class="planet planet-3"></div>
	</div>

	<!-- 宇航员层 - 增加数量 -->
	<div class="astronaut-layer">
		<div class="astronaut astronaut-1"></div>
		<div class="astronaut astronaut-2"></div>
	</div>

	<!-- 流星层 -->
	<div class="meteor-layer">
		<div class="meteor meteor-1"></div>
		<div class="meteor meteor-2"></div>
		<div class="meteor meteor-3"></div>
	</div>

	<!-- 卫星层 -->
	<div class="satellite-layer">
		<div class="satellite"></div>
	</div>

	<!-- 飞船层 -->
	<div class="spaceship-layer">
		<div class="spaceship"></div>
	</div>
</div>

<style>
	.universe-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	/* 星空层 - 多层闪烁星星 */
	.stars-layer {
		position: absolute;
		width: 100%;
		height: 100%;
		background-image:
			radial-gradient(2px 2px at 20% 30%, white, transparent),
			radial-gradient(2px 2px at 60% 70%, rgba(255, 255, 255, 0.8), transparent),
			radial-gradient(1px 1px at 50% 50%, white, transparent),
			radial-gradient(1px 1px at 80% 10%, rgba(255, 255, 255, 0.6), transparent),
			radial-gradient(2px 2px at 90% 60%, white, transparent),
			radial-gradient(1px 1px at 33% 80%, rgba(255, 255, 255, 0.7), transparent),
			radial-gradient(1px 1px at 15% 90%, white, transparent),
			radial-gradient(1px 1px at 40% 20%, rgba(255, 255, 255, 0.9), transparent),
			radial-gradient(2px 2px at 75% 45%, white, transparent),
			radial-gradient(1px 1px at 25% 65%, rgba(255, 255, 255, 0.8), transparent);
		background-size: 200% 200%;
		background-position:
			0% 0%, 40% 60%, 130% 270%, 70% 100%,
			100% 100%, 50% 100%, 80% 30%, 20% 80%,
			60% 20%, 90% 90%;
		animation: twinkle 4s ease-in-out infinite alternate;
	}

	@keyframes twinkle {
		0%, 100% {
			opacity: 0.5;
		}
		50% {
			opacity: 0.9;
		}
	}

	/* 星云层 - 彩色渐变云雾 */
	.nebula-layer {
		position: absolute;
		width: 100%;
		height: 100%;
		background:
			radial-gradient(ellipse at 20% 30%, rgba(138, 43, 226, 0.15) 0%, transparent 50%),
			radial-gradient(ellipse at 80% 70%, rgba(75, 0, 130, 0.12) 0%, transparent 50%),
			radial-gradient(ellipse at 50% 50%, rgba(25, 25, 112, 0.1) 0%, transparent 60%),
			radial-gradient(ellipse at 70% 20%, rgba(72, 61, 139, 0.08) 0%, transparent 45%);
		animation: nebulaDrift 20s ease-in-out infinite alternate;
	}

	@keyframes nebulaDrift {
		0% {
			transform: translate(0, 0) scale(1);
			opacity: 0.6;
		}
		50% {
			transform: translate(20px, -15px) scale(1.05);
			opacity: 0.8;
		}
		100% {
			transform: translate(-10px, 10px) scale(0.98);
			opacity: 0.7;
		}
	}

	/* 行星层 - 增强 3D 效果 */
	.planets-layer {
		position: absolute;
		width: 100%;
		height: 100%;
		perspective: 1000px;
	}

	.planet {
		position: absolute;
		border-radius: 50%;
		opacity: 0.75;
		filter: blur(0.5px);
		transform-style: preserve-3d;
		transition: transform 0.3s ease;
	}

	.planet:hover {
		transform: scale(1.1) translateZ(20px);
		opacity: 0.9;
	}

	/* 火星 - 带地形纹理 */
	.planet-1 {
		width: 120px;
		height: 120px;
		top: 15%;
		right: 10%;
		background:
			radial-gradient(circle at 25% 35%, rgba(139, 69, 19, 0.3) 0%, transparent 15%),
			radial-gradient(circle at 60% 50%, rgba(101, 67, 33, 0.4) 0%, transparent 20%),
			radial-gradient(circle at 40% 70%, rgba(160, 82, 45, 0.3) 0%, transparent 18%),
			radial-gradient(circle at 30% 30%, #f4a460, #d2691e 40%, #8b4513 65%, #2c1810);
		box-shadow:
			inset -25px -25px 50px rgba(0, 0, 0, 0.6),
			inset 15px 15px 30px rgba(244, 164, 96, 0.2),
			0 0 50px rgba(244, 164, 96, 0.4),
			0 0 80px rgba(244, 164, 96, 0.2);
		animation: planetFloat1 30s ease-in-out infinite, planetRotate1 60s linear infinite;
	}

	/* 蓝色行星 - 带云层 */
	.planet-2 {
		width: 90px;
		height: 90px;
		bottom: 20%;
		left: 15%;
		background:
			radial-gradient(ellipse at 30% 40%, rgba(255, 255, 255, 0.4) 0%, transparent 25%),
			radial-gradient(ellipse at 70% 60%, rgba(255, 255, 255, 0.3) 0%, transparent 30%),
			radial-gradient(circle at 35% 35%, #87ceeb, #4682b4 45%, #4169e1 60%, #191970);
		box-shadow:
			inset -20px -20px 40px rgba(0, 0, 0, 0.5),
			inset 12px 12px 25px rgba(135, 206, 235, 0.3),
			0 0 40px rgba(65, 105, 225, 0.5),
			0 0 70px rgba(65, 105, 225, 0.3);
		animation: planetFloat2 25s ease-in-out infinite, planetRotate2 50s linear infinite;
	}

	/* 紫色星球 - 带光环提示 */
	.planet-3 {
		width: 70px;
		height: 70px;
		top: 60%;
		right: 25%;
		background:
			radial-gradient(circle at 45% 35%, rgba(221, 160, 221, 0.3) 0%, transparent 20%),
			radial-gradient(circle at 40% 30%, #dda0dd, #ba55d3 50%, #8b008b 65%, #4b0082);
		box-shadow:
			inset -15px -15px 30px rgba(0, 0, 0, 0.5),
			inset 10px 10px 20px rgba(221, 160, 221, 0.2),
			0 0 35px rgba(221, 160, 221, 0.4),
			0 0 60px rgba(138, 43, 226, 0.3);
		animation: planetFloat3 35s ease-in-out infinite, planetRotate3 55s linear infinite;
	}

	.planet-3::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 120%;
		height: 20%;
		background: rgba(138, 43, 226, 0.15);
		border-radius: 50%;
		transform: translate(-50%, -50%) rotateX(75deg);
		box-shadow: 0 0 15px rgba(138, 43, 226, 0.3);
	}

	@keyframes planetFloat1 {
		0%, 100% {
			transform: translateY(0px) translateX(0px) rotateY(0deg);
		}
		50% {
			transform: translateY(-30px) translateX(20px) rotateY(10deg);
		}
	}

	@keyframes planetFloat2 {
		0%, 100% {
			transform: translateY(0px) translateX(0px) rotateY(0deg);
		}
		50% {
			transform: translateY(25px) translateX(-15px) rotateY(-8deg);
		}
	}

	@keyframes planetFloat3 {
		0%, 100% {
			transform: translateY(0px) translateX(0px) rotateY(0deg);
		}
		50% {
			transform: translateY(-20px) translateX(-25px) rotateY(12deg);
		}
	}

	@keyframes planetRotate1 {
		from {
			background-position: 0% 0%;
		}
		to {
			background-position: 100% 100%;
		}
	}

	@keyframes planetRotate2 {
		from {
			filter: hue-rotate(0deg) blur(0.5px);
		}
		to {
			filter: hue-rotate(360deg) blur(0.5px);
		}
	}

	@keyframes planetRotate3 {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	/* 宇航员层 - 多个宇航员 */
	.astronaut-layer {
		position: absolute;
		width: 100%;
		height: 100%;
	}

	.astronaut {
		position: absolute;
		width: 100px;
		height: 120px;
		opacity: 0.8;
		filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.4));
	}

	.astronaut-1 {
		top: 40%;
		left: 5%;
		animation: astronautFloat1 40s ease-in-out infinite;
	}

	.astronaut-2 {
		top: 70%;
		right: 10%;
		animation: astronautFloat2 45s ease-in-out infinite;
	}

	.astronaut::before {
		content: "👨‍🚀";
		font-size: 80px;
		position: absolute;
	}

	@keyframes astronautFloat1 {
		0% {
			transform: translate(0, 0) rotate(-5deg);
		}
		25% {
			transform: translate(calc(90vw), -100px) rotate(5deg);
		}
		50% {
			transform: translate(calc(85vw), 50px) rotate(-3deg);
		}
		75% {
			transform: translate(calc(45vw), -50px) rotate(4deg);
		}
		100% {
			transform: translate(0, 0) rotate(-5deg);
		}
	}

	@keyframes astronautFloat2 {
		0% {
			transform: translate(0, 0) rotate(8deg) scale(0.9);
		}
		33% {
			transform: translate(calc(-70vw), 80px) rotate(-6deg) scale(0.95);
		}
		66% {
			transform: translate(calc(-60vw), -60px) rotate(7deg) scale(0.92);
		}
		100% {
			transform: translate(0, 0) rotate(8deg) scale(0.9);
		}
	}

	/* 流星层 */
	.meteor-layer {
		position: absolute;
		width: 100%;
		height: 100%;
		overflow: hidden;
	}

	.meteor {
		position: absolute;
		width: 2px;
		height: 80px;
		background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.8) 50%, rgba(173, 216, 230, 0.6) 100%);
		opacity: 0;
		transform: rotate(-45deg);
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
	}

	.meteor-1 {
		top: 10%;
		right: 20%;
		animation: meteorFall1 3s ease-in infinite;
	}

	.meteor-2 {
		top: 30%;
		right: 60%;
		animation: meteorFall2 4s ease-in infinite 1.5s;
	}

	.meteor-3 {
		top: 50%;
		right: 80%;
		animation: meteorFall3 3.5s ease-in infinite 2.8s;
	}

	@keyframes meteorFall1 {
		0% {
			opacity: 0;
			transform: translate(0, 0) rotate(-45deg);
		}
		10% {
			opacity: 1;
		}
		90% {
			opacity: 0.5;
		}
		100% {
			opacity: 0;
			transform: translate(-400px, 400px) rotate(-45deg);
		}
	}

	@keyframes meteorFall2 {
		0% {
			opacity: 0;
			transform: translate(0, 0) rotate(-40deg);
		}
		10% {
			opacity: 1;
		}
		90% {
			opacity: 0.6;
		}
		100% {
			opacity: 0;
			transform: translate(-500px, 450px) rotate(-40deg);
		}
	}

	@keyframes meteorFall3 {
		0% {
			opacity: 0;
			transform: translate(0, 0) rotate(-50deg);
		}
		10% {
			opacity: 1;
		}
		90% {
			opacity: 0.4;
		}
		100% {
			opacity: 0;
			transform: translate(-450px, 420px) rotate(-50deg);
		}
	}

	/* 卫星层 */
	.satellite-layer {
		position: absolute;
		width: 100%;
		height: 100%;
	}

	.satellite {
		position: absolute;
		width: 60px;
		height: 40px;
		top: 25%;
		left: 70%;
		opacity: 0.7;
		animation: satelliteOrbit 50s linear infinite;
	}

	.satellite::before {
		content: "🛰️";
		font-size: 40px;
		position: absolute;
		filter: drop-shadow(0 0 8px rgba(200, 200, 255, 0.6));
	}

	@keyframes satelliteOrbit {
		0% {
			transform: translate(0, 0) rotate(0deg);
		}
		25% {
			transform: translate(-200px, -100px) rotate(90deg);
		}
		50% {
			transform: translate(-300px, 0) rotate(180deg);
		}
		75% {
			transform: translate(-200px, 100px) rotate(270deg);
		}
		100% {
			transform: translate(0, 0) rotate(360deg);
		}
	}

	/* 飞船层 */
	.spaceship-layer {
		position: absolute;
		width: 100%;
		height: 100%;
	}

	.spaceship {
		position: absolute;
		width: 80px;
		height: 60px;
		bottom: 30%;
		right: -100px;
		opacity: 0.75;
		animation: spaceshipFly 35s linear infinite;
	}

	.spaceship::before {
		content: "🚀";
		font-size: 60px;
		position: absolute;
		filter: drop-shadow(0 0 12px rgba(255, 200, 100, 0.5));
	}

	@keyframes spaceshipFly {
		0% {
			transform: translate(0, 0) rotate(-20deg);
			right: -100px;
		}
		100% {
			transform: translate(0, -50px) rotate(-15deg);
			right: calc(100% + 100px);
		}
	}

	/* 响应式调整 */
	@media (max-width: 768px) {
		.planet-1 {
			width: 80px;
			height: 80px;
		}

		.planet-2 {
			width: 60px;
			height: 60px;
		}

		.planet-3 {
			width: 40px;
			height: 40px;
		}

		.astronaut-1,
		.astronaut-2 {
			width: 60px;
			height: 72px;
		}

		.astronaut::before {
			font-size: 50px;
		}

		.satellite {
			width: 40px;
			height: 30px;
		}

		.satellite::before {
			font-size: 30px;
		}

		.spaceship {
			width: 60px;
			height: 45px;
		}

		.spaceship::before {
			font-size: 45px;
		}

		.meteor {
			height: 60px;
		}
	}
</style>
