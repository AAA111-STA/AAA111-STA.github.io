---
// 宇宙星空背景组件
---

<div class="cosmic-background" aria-hidden="true">
	<div class="stars"></div>
	<div class="stars2"></div>
	<div class="stars3"></div>
	<div class="nebula"></div>
</div>

<style>
	.cosmic-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	.stars,
	.stars2,
	.stars3 {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: transparent;
	}

	/* 大星星 */
	.stars {
		background-image: radial-gradient(2px 2px at 20px 30px, #eee, rgba(0, 0, 0, 0)),
			radial-gradient(2px 2px at 60px 70px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 50px 50px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 130px 80px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(2px 2px at 90px 10px, #fff, rgba(0, 0, 0, 0));
		background-repeat: repeat;
		background-size: 200px 200px;
		animation: twinkle 5s ease-in-out infinite;
		opacity: 0.5;
	}

	/* 中等星星 */
	.stars2 {
		background-image: radial-gradient(1px 1px at 40px 60px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 110px 90px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 170px 30px, #fff, rgba(0, 0, 0, 0));
		background-repeat: repeat;
		background-size: 250px 250px;
		animation: twinkle 7s ease-in-out infinite;
		animation-delay: 1s;
		opacity: 0.4;
	}

	/* 小星星 */
	.stars3 {
		background-image: radial-gradient(1px 1px at 75px 125px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 100px 75px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 142px 147px, #fff, rgba(0, 0, 0, 0)),
			radial-gradient(1px 1px at 195px 115px, #fff, rgba(0, 0, 0, 0));
		background-repeat: repeat;
		background-size: 300px 300px;
		animation: twinkle 10s ease-in-out infinite;
		animation-delay: 2s;
		opacity: 0.3;
	}

	/* 星云效果 */
	.nebula {
		position: absolute;
		top: -50%;
		right: -20%;
		width: 80%;
		height: 120%;
		background: radial-gradient(
			ellipse at center,
			rgba(123, 104, 238, 0.15) 0%,
			rgba(157, 141, 241, 0.08) 30%,
			transparent 70%
		);
		animation: nebulaDrift 30s ease-in-out infinite alternate;
		opacity: 0.6;
	}

	@keyframes twinkle {
		0%,
		100% {
			opacity: 0.3;
		}
		50% {
			opacity: 0.8;
		}
	}

	@keyframes nebulaDrift {
		0% {
			transform: translate(0, 0) scale(1);
		}
		100% {
			transform: translate(-10%, 5%) scale(1.1);
		}
	}

	/* 暗色模式调整 */
	:global([data-theme="dark"]) .stars,
	:global([data-theme="dark"]) .stars2,
	:global([data-theme="dark"]) .stars3 {
		opacity: 0.8;
	}

	:global([data-theme="dark"]) .nebula {
		opacity: 0.4;
	}

	/* 亮色模式减弱效果 */
	:global([data-theme="light"]) .stars,
	:global([data-theme="light"]) .stars2,
	:global([data-theme="light"]) .stars3 {
		opacity: 0.15;
	}

	:global([data-theme="light"]) .nebula {
		opacity: 0.1;
	}
</style>
