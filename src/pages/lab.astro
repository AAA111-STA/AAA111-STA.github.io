---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "宇宙实验室",
	description: "探索宇宙的奥秘，进行天文观测和实验",
};

// 四个交互式工具，均对应真实的子页面
const tools = [
	{
		icon: "🪐",
		title: "行星轨道模拟",
		desc: "可视化太阳系八大行星的轨道运动，直观理解开普勒定律。",
		href: "/lab/orbits",
		cta: "启动模拟",
	},
	{
		icon: "🌠",
		title: "流星雨预测",
		desc: "全年主要流星雨的活动时间、辐射点与观测指南。",
		href: "/lab/meteor-showers",
		cta: "查看预测",
	},
	{
		icon: "⭐",
		title: "恒星光谱分类",
		desc: "了解哈佛光谱分类 OBAFGKM，以及恒星的温度与颜色特征。",
		href: "/lab/spectra",
		cta: "开始学习",
	},
	{
		icon: "🌌",
		title: "星系形态图鉴",
		desc: "哈勃星系分类法，探索椭圆、旋涡、棒旋和不规则星系。",
		href: "/lab/galaxies",
		cta: "浏览图鉴",
	},
];
---

<PageLayout meta={{ title: meta.title, description: meta.description }}>
	<div class="space-y-8">
		<section class="animate">
			<h1 class="text-4xl font-bold mb-4">🔬 宇宙实验室</h1>
			<p class="text-lg opacity-80 mb-6">
				这里是我们探索宇宙奥秘的实验空间，包含天文数据、可视化模拟和交互式科普工具。
			</p>
		</section>

		<section class="animate grid gap-6 sm:grid-cols-2">
			{
				tools.map((tool) => (
					<a
						href={tool.href}
						class="block p-6 rounded-lg bg-accent/10 border border-accent/20 hover:border-accent/50 hover:bg-accent/15 transition-all duration-300"
					>
						<h2 class="text-2xl font-semibold mb-3">
							{tool.icon} {tool.title}
						</h2>
						<p class="opacity-80 mb-4 text-sm">{tool.desc}</p>
						<span class="text-accent">{tool.cta} →</span>
					</a>
				))
			}
		</section>

		<section class="animate">
			<h2 class="text-2xl font-semibold mb-4">🧪 正在进行的实验</h2>
			<ul class="space-y-3">
				<li class="flex items-start gap-3">
					<span class="text-accent">•</span>
					<div>
						<strong>月球摄影技术优化</strong>
						<p class="text-sm opacity-70">使用不同曝光参数拍摄月球细节</p>
					</div>
				</li>
				<li class="flex items-start gap-3">
					<span class="text-accent">•</span>
					<div>
						<strong>木星大红斑变化监测</strong>
						<p class="text-sm opacity-70">长期观测大红斑的尺寸和颜色变化</p>
					</div>
				</li>
				<li class="flex items-start gap-3">
					<span class="text-accent">•</span>
					<div>
						<strong>系外行星凌日探测</strong>
						<p class="text-sm opacity-70">通过光度变化寻找潜在的系外行星</p>
					</div>
				</li>
			</ul>
		</section>
	</div>
</PageLayout>
