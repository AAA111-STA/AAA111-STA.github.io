---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "探索宇宙奥秘的天文知识站",
	title: "关于",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">关于本站</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			星语宇宙是一个专注于天文科普的知识站，致力于用通俗易懂的语言，向大众传播天文学知识。
		</p>
		<p>本站的特色包括：</p>
		<ul class="list-inside list-disc" role="list">
			<li>深入浅出的天文科普文章</li>
			<li>太阳系、深空天体、宇宙学等多元主题</li>
			<li>精心设计的深空宇宙主题界面</li>
			<li>动态星空背景，沉浸式阅读体验</li>
			<li>支持明暗模式切换</li>
			<li>快速响应式设计，适配各种设备</li>
		</ul>
		<p>
			无论你是天文爱好者、学生，还是对宇宙充满好奇，都欢迎在这里探索星辰大海的奥秘。
		</p>
	</div>
</PageLayout>
