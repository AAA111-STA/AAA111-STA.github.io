---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	description: "按主题分类浏览所有天文文章",
	title: "标签",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">标签</h1>
	<ul class="space-y-4">
		{
			allTags.map(([tag, val]) => (
				<li class="group flex items-center gap-x-2 transition-all duration-300 hover:translate-x-2">
					<svg class="inline-block w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor">
						<circle cx="12" cy="12" r="8" stroke-width="1.5" opacity="0.6"/>
						<circle cx="12" cy="12" r="4" fill="currentColor" opacity="0.8"/>
						<circle cx="8" cy="8" r="1" fill="currentColor"/>
						<circle cx="16" cy="10" r="1" fill="currentColor"/>
					</svg>
					<a
						class="cactus-link inline-block group-hover:text-accent-2"
						href={`/tags/${tag}/`}
						title={`查看标签：${tag}`}
					>
						&#35;{tag}
					</a>
					<span class="text-muted inline-block text-sm">
						{val} 篇文章
					</span>
				</li>
			))
		}
	</ul>
</PageLayout>
